[Unit]
Description=Oat Strategy Extractor — Observer
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/polymarket_bot
ExecStart=/usr/bin/python3 /root/polymarket_bot/oat_observer.py
Restart=always
RestartSec=10
StandardOutput=null
StandardError=null

# Environment
EnvironmentFile=/root/.env

[Install]
WantedBy=multi-user.target
